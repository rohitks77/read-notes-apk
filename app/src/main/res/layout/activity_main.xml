<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/icon_bg">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/brand" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/brand_accent"
        android:progressBackgroundTint="@android:color/transparent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Offline view: matches splash cream/warm palette -->
    <FrameLayout
        android:id="@+id/offlineView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@color/icon_bg">

        <LinearLayout
            android:id="@+id/offlineContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp">

            <ImageView
                android:id="@+id/offlineIcon"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_offline_cloud"
                android:alpha="0.95"
                android:contentDescription="@string/offline_title" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/offline_title"
                android:textColor="#0F172A"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="@string/offline_subtitle"
                android:textColor="#64748B"
                android:lineSpacingExtra="4dp"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/retryButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:paddingHorizontal="36dp"
                android:paddingVertical="14dp"
                android:background="@drawable/bg_retry_button"
                android:text="@string/retry"
                android:textColor="#FAF7F2"
                android:textStyle="bold"
                android:textSize="14sp"
                android:letterSpacing="0.05"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </FrameLayout>

    <!-- Branded splash overlay: icon stays anchored at same spot as system splash,
         wordmark + tagline + loader render below so nothing "pops in" late. -->
    <FrameLayout
        android:id="@+id/splashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/icon_bg"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/splashIcon"
                android:layout_width="192dp"
                android:layout_height="192dp"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="@string/app_name" />

            <TextView
                android:id="@+id/splashTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-44dp"
                android:text="@string/app_name"
                android:textColor="#0F172A"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.18"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/splashTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/app_tagline"
                android:textColor="#64748B"
                android:textSize="13sp"
                android:letterSpacing="0.04" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/splashProgress"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="72dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/brand_accent" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
